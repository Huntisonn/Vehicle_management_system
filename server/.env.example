# ─────────────────────────────────────────────
#  RentiGo Server — Environment Variables (Render MVP)
# ─────────────────────────────────────────────

# ─── REQUIRED ─────────────────────────────────
MONGODB_URI=mongodb+srv://admin:secure_password@cluster.mongodb.net/rentigo

# ─── OPTIONAL / RECOMMENDED FOR PRODUCTION ───
# (If omitted, safe defaults will be used for MVP)
PORT=5000
NODE_ENV=production
CLIENT_URL=http://localhost:5173
JWT_ACCESS_SECRET=your_super_secret_access_key_make_it_long_and_random
JWT_REFRESH_SECRET=your_super_secret_refresh_key_make_it_long_and_random

# ─── OPTIONAL INTEGRATIONS ───────────────────
# Cloudinary (If omitted, files are saved locally to src/uploads)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Email (If omitted, emails will be logged to server console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_gmail_app_password
# EMAIL_FROM=RentiGo <noreply@rentigo.io>
